generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum RoleEmpresa {
  DONO
  ADMIN
  ENGENHEIRO
  MESTRE
  ENCARREGADO
  AUXILIAR_ENGENHARIA
  ALMOXARIFE
  ESTAGIARIO_ENGENHARIA
  ESTAGIARIO_ALMOXARIFE
}

enum RoleObra {
  RESPONSAVEL
  ENGENHEIRO
  MESTRE
  ENCARREGADO
  VISUALIZADOR
}

enum PlanoEmpresa {
  BASICO
  PRO
  ENTERPRISE
}

enum StatusObra {
  PLANEJAMENTO
  EM_ANDAMENTO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum StatusRDO {
  RASCUNHO
  ENVIADO       // aguardando engenheiro
  EM_REVISAO    // engenheiro aprovou, aguardando coordenador
  APROVADO      // coordenador aprovou → atualiza tarefas
  REJEITADO
}

enum StatusFVS {
  PENDENTE
  EM_INSPECAO
  APROVADO
  REJEITADO
  RETRABALHO
}

enum StatusFVM {
  PENDENTE
  RECEBIDO
  APROVADO
  REJEITADO
  DEVOLVIDO
}

enum StatusOcorrencia {
  ABERTA
  EM_ANALISE
  RESOLVIDA
  FECHADA
}

enum TipoOcorrencia {
  SEGURANCA
  QUALIDADE
  PRAZO
  CUSTO
  AMBIENTAL
  OUTRO
}

enum StatusSolicitacao {
  RASCUNHO
  PENDENTE
  APROVADA
  REJEITADA
  CANCELADA
}

enum StatusPedido {
  RASCUNHO
  ENVIADO
  CONFIRMADO
  ENTREGUE_PARCIAL
  ENTREGUE
  CANCELADO
}

enum TipoMidia {
  FOTO
  VIDEO
}

enum StatusEquipamento {
  DISPONIVEL
  EM_USO
  MANUTENCAO
  INATIVO
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

enum RecorrenciaTipo {
  NENHUMA
  DIARIA
  SEMANAL
  MENSAL
}

enum StatusPresencaMO {
  PRESENTE
  AFASTADO
  ATESTADO
  DESLOCANDO
  FALTA_JUSTIFICADA
  FERIAS
  FOLGA
  LICENCA
  TREINAMENTO
  VIAGEM
}

// ─── Multi-tenant ─────────────────────────────────────────────────────────────

model Empresa {
  id                  String       @id @default(cuid())
  nome                String
  cnpj                String?      @unique
  plano               PlanoEmpresa @default(BASICO)
  logoUrl             String?
  camposPersonalizados Json?        // [{ id, nome, tipo, secao, obrigatorio, opcoes? }]
  planosContas        Json?         // { "Materiais": "1.1.01", "Servicos": "1.1.02", centroCusto?: "CC001" }
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  usuarios           Usuario[]
  obras              Obra[]
  fornecedores       Fornecedor[]
  materiais          MaterialCatalogo[]
  equipamentos       Equipamento[]
  convites           Convite[]
  templatesFvs       TemplateFVS[]
  templatesChecklist TemplateChecklist[]
  integracao         IntegracaoConfig?
  modelosRelatorio   ModeloRelatorio[]
  mensagensAssistente MensagemAssistente[]
  dashboardConfigs    DashboardConfig[]
}

model ModeloRelatorio {
  id             String   @id @default(cuid())
  empresaId      String
  nome           String
  nomeRelatorio  String   @default("Relatório Diário de Obra")
  logoUrl        String?
  secoesVisiveis Json     @default("[\"equipe\",\"atividades\",\"equipamentos\",\"ocorrencias\",\"materiais\",\"clima\",\"fotos\",\"assinaturas\"]")
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model Usuario {
  id         String      @id @default(cuid())
  authId     String?     @unique
  email      String      @unique
  nome       String
  telefone   String?
  avatarUrl  String?
  role       RoleEmpresa @default(ENGENHEIRO)
  ativo      Boolean     @default(true)
  empresaId  String
  permissoes Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  empresa           Empresa             @relation(fields: [empresaId], references: [id])
  obrasVinculo      ObraUsuario[]
  rdos              RDO[]
  fvsAprovadas      FVS[]               @relation("FVSResponsavel")
  ocorrencias       Ocorrencia[]
  mensagens         MensagemChat[]
  solicitacoes      SolicitacaoCompra[]
  pushSubscriptions PushSubscription[]
  verificacoesRDO   VerificacaoRDO[]
  mensagensAssistente MensagemAssistente[]
  dashboardConfig     DashboardConfig?
}

// ─── Obras ────────────────────────────────────────────────────────────────────

model Obra {
  id          String     @id @default(cuid())
  nome        String
  descricao   String?
  endereco    String?
  cidade      String?
  estado      String?
  status      StatusObra @default(PLANEJAMENTO)
  progresso   Float      @default(0)
  orcamento   Float?
  custoAtual  Float      @default(0)
  dataInicio  DateTime?
  dataFim     DateTime?
  imagemUrl           String?
  siengeId            String?
  grupo               String?
  numContrato         String?
  prazoContratualDias Int?
  equipePredef        Json?
  equipamentosPredef  Json?
  empresaId           String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  empresa              Empresa               @relation(fields: [empresaId], references: [id])
  usuarios             ObraUsuario[]
  rdos                 RDO[]
  fvs                  FVS[]
  fvm                  FVM[]
  ocorrencias          Ocorrencia[]
  plantas              Planta[]
  equipe               MembroEquipe[]
  documentos           Documento[]
  midias               Midia[]
  mensagens            MensagemChat[]
  solicitacoes         SolicitacaoCompra[]
  movimentacoes        MovimentacaoMaterial[]
  lancamentos          LancamentoFinanceiro[]
  medicoes             MedicaoObra[]
  respostasChecklist   RespostaChecklist[]
  tarefas              TarefaObra[]
}

model ObraUsuario {
  id        String   @id @default(cuid())
  obraId    String
  usuarioId String
  role      RoleObra @default(VISUALIZADOR)
  createdAt DateTime @default(now())

  obra    Obra    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([obraId, usuarioId])
}

// ─── RDO ─────────────────────────────────────────────────────────────────────

model RDO {
  id             String    @id @default(cuid())
  obraId         String
  data           DateTime  @default(now())
  clima          String?
  temperaturaMin Float?
  temperaturaMax Float?
  ocorreuChuva   Boolean   @default(false)
  status         StatusRDO @default(RASCUNHO)
  observacoes    String?
  responsavelId  String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  siengeReportId           String?   // ID do RDO criado no Sienge (evita duplicatas)
  visualizacoes            Int       @default(0)
  valoresCamposPersonalizados Json?  // { [campoId]: valor }

  obra                Obra                  @relation(fields: [obraId], references: [id], onDelete: Cascade)
  responsavel         Usuario               @relation(fields: [responsavelId], references: [id])
  atividades          RDOAtividade[]
  equipe              RDOEquipe[]
  midias              Midia[]
  assinaturas         AssinaturaRDO[]
  materiaisRecebidos  RDOMaterialRecebido[]
  materiaisUtilizados RDOMaterialUtilizado[]
  verificacoes        VerificacaoRDO[]
}

model RDOAtividade {
  id            String      @id @default(cuid())
  rdoId         String
  descricao     String
  quantidade    Float?
  unidade       String?
  observacao    String?
  tarefaObraId  String?

  rdo        RDO         @relation(fields: [rdoId], references: [id], onDelete: Cascade)
  tarefaObra TarefaObra? @relation(fields: [tarefaObraId], references: [id])
}

model RDOEquipe {
  id             String           @id @default(cuid())
  rdoId          String
  funcao         String
  quantidade     Int
  observacao     String?
  statusPresenca StatusPresencaMO @default(PRESENTE)

  rdo RDO @relation(fields: [rdoId], references: [id], onDelete: Cascade)
}

model AssinaturaRDO {
  id        String   @id @default(cuid())
  rdoId     String
  label     String   // ex: "Responsável Técnico", "Mestre de Obras"
  imagemUrl String?
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  rdo RDO @relation(fields: [rdoId], references: [id], onDelete: Cascade)
}

model RDOMaterialRecebido {
  id           String  @id @default(cuid())
  rdoId        String
  materialNome String
  quantidade   Float
  unidade      String?
  fornecedor   String?

  rdo RDO @relation(fields: [rdoId], references: [id], onDelete: Cascade)
}

model RDOMaterialUtilizado {
  id            String  @id @default(cuid())
  rdoId         String
  materialNome  String
  quantidade    Float
  unidade       String?
  localAplicado String?

  rdo RDO @relation(fields: [rdoId], references: [id], onDelete: Cascade)
}

// ─── FVS ─────────────────────────────────────────────────────────────────────

model FVS {
  id            String    @id @default(cuid())
  obraId        String
  codigo        String?
  servico       String
  responsavelId String
  status        StatusFVS @default(PENDENTE)
  data          DateTime  @default(now())
  observacoes   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  obra        Obra      @relation(fields: [obraId], references: [id], onDelete: Cascade)
  responsavel Usuario   @relation("FVSResponsavel", fields: [responsavelId], references: [id])
  itens       FVSItem[]
  midias      Midia[]
}

model FVSItem {
  id         String   @id @default(cuid())
  fvsId      String
  descricao  String
  aprovado   Boolean?
  observacao String?

  fvs FVS @relation(fields: [fvsId], references: [id], onDelete: Cascade)
}

// ─── FVM ─────────────────────────────────────────────────────────────────────

model FVM {
  id           String    @id @default(cuid())
  obraId       String
  codigo       String?
  material     String
  fornecedorNome String?
  quantidade   Float
  unidade      String?
  status       StatusFVM @default(PENDENTE)
  data         DateTime  @default(now())
  notaFiscal   String?
  observacoes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  obra   Obra    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  midias Midia[]
}

// ─── Ocorrências + Mapa Visual ───────────────────────────────────────────────

model Ocorrencia {
  id            String           @id @default(cuid())
  obraId        String
  tipo          TipoOcorrencia   @default(OUTRO)
  titulo        String
  descricao     String?
  status        StatusOcorrencia @default(ABERTA)
  prioridade    Int              @default(2)
  data          DateTime         @default(now())
  plantaId      String?
  posX          Float?
  posY          Float?
  responsavelId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  obra        Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  planta      Planta?  @relation(fields: [plantaId], references: [id])
  responsavel Usuario? @relation(fields: [responsavelId], references: [id])
  midias      Midia[]
}

model Planta {
  id        String   @id @default(cuid())
  obraId    String
  nome      String
  url       String
  createdAt DateTime @default(now())

  obra        Obra         @relation(fields: [obraId], references: [id], onDelete: Cascade)
  ocorrencias Ocorrencia[]
}

// ─── Equipe ───────────────────────────────────────────────────────────────────

model MembroEquipe {
  id          String    @id @default(cuid())
  obraId      String
  nome        String
  funcao      String
  cpf              String?
  siengeCreditorId Int?
  telefone         String?
  empresaNome String?
  dataEntrada DateTime  @default(now())
  dataSaida   DateTime?
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

// ─── Suprimentos ─────────────────────────────────────────────────────────────

model Fornecedor {
  id               String   @id @default(cuid())
  empresaId        String
  nome             String
  cnpj             String?
  categoria        String?
  cidade           String?
  estado           String?
  telefone         String?
  email            String?
  site             String?
  ativo            Boolean  @default(true)
  siengeCreditorId Int?
  notaMedia        Float?
  totalAvaliacoes  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  empresa Empresa        @relation(fields: [empresaId], references: [id])
  pedidos PedidoCompra[]
}

model MaterialCatalogo {
  id            String   @id @default(cuid())
  empresaId     String
  nome          String
  descricao     String?
  unidade       String
  categoria     String?
  precoUnitario Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  empresa          Empresa                @relation(fields: [empresaId], references: [id])
  movimentacoes    MovimentacaoMaterial[]
  itensSolicitacao ItemSolicitacao[]
  itensPedido      ItemPedido[]
}

model MovimentacaoMaterial {
  id         String   @id @default(cuid())
  obraId     String
  materialId String
  tipo       String
  quantidade Float
  data       DateTime @default(now())
  observacao String?

  obra     Obra             @relation(fields: [obraId], references: [id])
  material MaterialCatalogo @relation(fields: [materialId], references: [id])
}

model Equipamento {
  id        String            @id @default(cuid())
  empresaId String
  nome      String
  tipo      String?
  modelo    String?
  placa     String?
  status    StatusEquipamento @default(DISPONIVEL)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
}

model SolicitacaoCompra {
  id            String            @id @default(cuid())
  obraId        String
  solicitanteId String
  status        StatusSolicitacao @default(RASCUNHO)
  urgencia      Int               @default(2)
  observacoes              String?
  siengePurchaseRequestId  Int?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  obra        Obra              @relation(fields: [obraId], references: [id])
  solicitante Usuario           @relation(fields: [solicitanteId], references: [id])
  itens       ItemSolicitacao[]
  pedidos     PedidoCompra[]
}

model ItemSolicitacao {
  id              String  @id @default(cuid())
  solicitacaoId   String
  materialId      String
  quantidade      Float
  unidade         String?
  observacao      String?
  statusAprovacao String?
  obsAprovacao    String?

  solicitacao SolicitacaoCompra @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  material    MaterialCatalogo  @relation(fields: [materialId], references: [id])
}

model PedidoCompra {
  id               String       @id @default(cuid())
  solicitacaoId    String?
  fornecedorId     String
  status           StatusPedido @default(RASCUNHO)
  total            Float?
  previsaoEntrega  DateTime?
  observacoes      String?
  notaFiscalNumero      String?
  notaFiscalUrl         String?
  notaFiscalValor       Float?
  siengePurchaseOrderId Int?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  solicitacao SolicitacaoCompra? @relation(fields: [solicitacaoId], references: [id])
  fornecedor  Fornecedor         @relation(fields: [fornecedorId], references: [id])
  itens       ItemPedido[]
}

model ItemPedido {
  id         String  @id @default(cuid())
  pedidoId   String
  materialId String
  quantidade Float
  precoUnit  Float?
  total      Float?
  unidade    String?

  pedido   PedidoCompra     @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  material MaterialCatalogo @relation(fields: [materialId], references: [id])
}

// ─── Documentos ───────────────────────────────────────────────────────────────

model Documento {
  id        String   @id @default(cuid())
  obraId    String
  nome      String
  categoria String
  url       String
  tipo      String?
  tamanho   Int?
  createdAt DateTime @default(now())

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model LancamentoFinanceiro {
  id                  String          @id @default(cuid())
  obraId              String
  tipo                TipoLancamento
  categoria           String?
  descricao           String
  valor               Float
  data                DateTime        @default(now())
  recorrencia         RecorrenciaTipo @default(NENHUMA)
  recorrenciaFim      DateTime?
  recorrenciaOrigemId String?
  createdAt           DateTime        @default(now())

  obra          Obra                   @relation(fields: [obraId], references: [id], onDelete: Cascade)
  recorrencias  LancamentoFinanceiro[] @relation("RecorrenciaOrigem")
  origem        LancamentoFinanceiro?  @relation("RecorrenciaOrigem", fields: [recorrenciaOrigemId], references: [id])
}

// ─── Mídia ────────────────────────────────────────────────────────────────────

model Midia {
  id           String    @id @default(cuid())
  obraId       String
  tipo         TipoMidia
  url          String
  thumbnailUrl String?
  descricao    String?
  rdoId        String?
  fvsId        String?
  fvmId        String?
  ocorrenciaId String?
  createdAt    DateTime  @default(now())

  obra       Obra        @relation(fields: [obraId], references: [id])
  rdo        RDO?        @relation(fields: [rdoId], references: [id])
  fvs        FVS?        @relation(fields: [fvsId], references: [id])
  fvm        FVM?        @relation(fields: [fvmId], references: [id])
  ocorrencia Ocorrencia? @relation(fields: [ocorrenciaId], references: [id])
}

// ─── Templates FVS ────────────────────────────────────────────────────────────

model TemplateFVS {
  id        String   @id @default(cuid())
  empresaId String
  nome      String
  servico   String
  createdAt DateTime @default(now())

  empresa Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens   TemplateFVSItem[]
}

model TemplateFVSItem {
  id         String @id @default(cuid())
  templateId String
  descricao  String
  ordem      Int    @default(0)

  template TemplateFVS @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ─── Convites ─────────────────────────────────────────────────────────────────

model Convite {
  id         String      @id @default(cuid())
  empresaId  String
  email      String
  role       RoleEmpresa @default(ENGENHEIRO)
  permissoes Json?
  token      String      @unique @default(cuid())
  usado      Boolean     @default(false)
  expiresAt  DateTime
  createdAt  DateTime    @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  empresaId   String
  obraId      String?
  entityType  String
  entityId    String
  acao        String
  usuarioId   String
  usuarioNome String
  detalhes    String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([obraId])
  @@index([empresaId])
}

// ─── Push Notifications ───────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  usuarioId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

// ─── Integrações ──────────────────────────────────────────────────────────────

model IntegracaoConfig {
  id               String   @id @default(cuid())
  empresaId        String   @unique
  tipo             String   @default("SIENGE")
  subdominio       String
  usuario          String
  senha            String
  ativo            Boolean  @default(true)
  webhookSecret    String?
  siengeWebhookId  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  empresa Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  syncs   IntegracaoSync[]
}

model IntegracaoSync {
  id           String   @id @default(cuid())
  integracaoId String
  tipo         String
  status       String
  detalhes     String?
  registros    Int      @default(0)
  createdAt    DateTime @default(now())

  integracao IntegracaoConfig @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model MensagemChat {
  id        String   @id @default(cuid())
  obraId    String
  usuarioId String
  conteudo  String
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  obra    Obra    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

// ─── Medição de Obra ──────────────────────────────────────────────────────────

model MedicaoObra {
  id        String      @id @default(cuid())
  obraId    String
  data      DateTime
  descricao String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  obra  Obra          @relation(fields: [obraId], references: [id], onDelete: Cascade)
  itens MedicaoItem[]
}

model MedicaoItem {
  id                  String  @id @default(cuid())
  medicaoId           String
  descricao           String
  unidade             String?
  qtdPrevista         Float?
  qtdMedida           Float
  percentual          Float?
  siengeProgressLogId String?

  medicao MedicaoObra @relation(fields: [medicaoId], references: [id], onDelete: Cascade)
}

// ─── Checklist Personalizável ──────────────────────────────────────────────────

model TemplateChecklist {
  id        String   @id @default(cuid())
  empresaId String
  nome      String
  descricao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa   Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens     ItemTemplateChecklist[]
  respostas RespostaChecklist[]
}

model ItemTemplateChecklist {
  id          String  @id @default(cuid())
  templateId  String
  descricao   String
  secao       String?
  obrigatorio Boolean @default(false)
  ordem       Int     @default(0)

  template  TemplateChecklist       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  respostas ItemRespostaChecklist[]
}

model RespostaChecklist {
  id             String   @id @default(cuid())
  obraId         String
  templateId     String
  data           DateTime @default(now())
  assinaturaUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  obra     Obra                    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  template TemplateChecklist       @relation(fields: [templateId], references: [id])
  itens    ItemRespostaChecklist[]
}

model ItemRespostaChecklist {
  id         String   @id @default(cuid())
  respostaId String
  itemId     String
  conforme   Boolean?
  observacao String?
  fotoUrl    String?

  resposta RespostaChecklist     @relation(fields: [respostaId], references: [id], onDelete: Cascade)
  item     ItemTemplateChecklist @relation(fields: [itemId], references: [id])
}

// ─── Lista de Tarefas da Obra (WBS nativa) ────────────────────────────────────

model TarefaObra {
  id                  String           @id @default(cuid())
  obraId              String
  parentId            String?
  codigo              String?
  nome                String
  setor               String?
  unidade             String           @default("un")
  quantidadeTotal     Float            @default(0)
  quantidadeExecutada Float            @default(0)
  percentual          Float            @default(0)
  status              StatusTarefaObra @default(NAO_INICIADO)
  ordem               Int              @default(0)
  criadoEm            DateTime         @default(now())
  atualizadoEm        DateTime         @updatedAt

  obra       Obra           @relation(fields: [obraId], references: [id], onDelete: Cascade)
  parent     TarefaObra?    @relation("SubTarefas", fields: [parentId], references: [id])
  filhos     TarefaObra[]   @relation("SubTarefas")
  atividades RDOAtividade[]
}

enum StatusTarefaObra {
  NAO_INICIADO
  EM_ANDAMENTO
  CONCLUIDO
  SUSPENSO
}


// ─── Verificação de RDO (fluxo 3 processos) ───────────────────────────────────

model VerificacaoRDO {
  id         String               @id @default(cuid())
  rdoId      String
  usuarioId  String
  etapa      EtapaVerificacaoRDO
  status     StatusVerificacaoRDO
  comentario String?
  criadoEm   DateTime             @default(now())

  rdo     RDO     @relation(fields: [rdoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

enum EtapaVerificacaoRDO {
  ENGENHEIRO
  COORDENADOR
}

enum StatusVerificacaoRDO {
  APROVADO
  REJEITADO
}

// ─── Dashboard Config ────────────────────────────────────────────────────────

model DashboardConfig {
  id        String   @id @default(cuid())
  usuarioId String   @unique
  empresaId String
  widgets   Json     // [{ id: WidgetId, visivel: boolean, ordem: number }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

// ─── Assistente IA ────────────────────────────────────────────────────────────

model MensagemAssistente {
  id        String   @id @default(cuid())
  usuarioId String
  empresaId String
  role      String   // "user" | "assistant"
  conteudo  String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([usuarioId, createdAt])
}
